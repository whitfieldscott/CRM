# Oklahoma Metrc (https://api-ok.metrc.com) — HTTP Basic: username = vendor key, password = user key.
METRC_USER_KEY=
# Optional integrator vendor key (username); leave empty if using user key only.
METRC_VENDOR_KEY=

SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_TEMPLATE_ID=
FROM_EMAIL=
BACKEND_URL=http://127.0.0.1:8000
TEST_EMAIL=
BUSINESS_ADDRESS=

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Used when Text Campaign Test Mode is ON (E.164 verified number).
TEST_SMS_TO=+1xxxxxxxxxx

# Phase 1: protect sensitive routes (see backend/admin_auth.py)
ADMIN_API_KEY=

# Production CORS (comma-separated). Local dev defaults to localhost:3000 only.
# CORS_ALLOW_ORIGINS=https://app.arkonesystems.com
